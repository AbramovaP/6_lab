@model ТП2лаб2.Models.Cake[]

@{
    // ВНУТРЕННИЙ ВСПОМОГАТЕЛЬНЫЙ МЕТОД (синхронная версия)
    HelperResult FormatPrice(decimal price)
    {
        return new HelperResult(writer => writer.Write($"{price:F2} руб."));
    }
}

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Список изделий";
}

<h2>Список кондитерских изделий</h2>

<p>
    @Html.ActionLink("Добавить новое изделие", "Create")
</p>

<table border="1" cellpadding="5" cellspacing="0">
    <tr>
        <th>@Html.LabelFor(model => model[0].Name)</th>
        <th>@Html.LabelFor(model => model[0].Type)</th>
        <th>@Html.LabelFor(model => model[0].Weight)</th>
        <th>@Html.LabelFor(model => model[0].Price)</th>
        <th>@Html.LabelFor(model => model[0].ProductionDate)</th>
        <th>@Html.LabelFor(model => model[0].Ingredients)</th>
        <th>Действия</th>
    </tr>

    @foreach (var cake in Model)
    {
        if (cake != null)
        {
            <tr>
                <td>@Html.DisplayFor(model => cake.Name)</td>
                <td>@Html.DisplayFor(model => cake.Type)</td>
                <td>@Html.DisplayFor(model => cake.Weight)</td>
                <td>
                    @if (ViewData["UseInternalHelper"] != null && (bool)ViewData["UseInternalHelper"])
                    {
                        @FormatPrice(cake.Price)
                    }
                    else
                    {
                        @ТП2лаб2.Helpers.CakeHelpers.FormatPriceWithVat(cake.Price)
                    }
                </td>
                <td>@Html.DisplayFor(model => cake.ProductionDate)</td>
                <td>@Html.DisplayFor(model => cake.Ingredients)</td>
                <td>
                    @Html.ActionLink("Редактировать", "Edit", new { id = cake.Id })
                </td>
            </tr>
        }
    }
</table>

<style>
    table {
        border-collapse: collapse;
        width: 100%;
        margin-top: 20px;
    }

    th, td {
        border: 1px solid #ddd;
        padding: 8px;
        text-align: left;
    }

    th {
        background-color: #f2f2f2;
    }

    tr:hover {
        background-color: #f5f5f5;
    }
</style>